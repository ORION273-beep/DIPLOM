# Site URL (public HTTPS address after TLS setup, or http://your-server-ip for first boot)
SITE_URL=http://localhost

# JWT secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long

# Set true when serving over HTTPS (required for auth cookies)
COOKIE_SECURE=false

# Payment webhook secret
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret

# Set true to force database seed on startup (wipes existing data!)
# RUN_SEED=true
