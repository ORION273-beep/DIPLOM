{
  "name": "kupikod-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/app src/components/auth src/components/catalog src/components/commerce src/components/layout src/components/marketing src/lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "backend:dev": "cd backend && npm run dev",
    "backend:start": "cd backend && npm run start",
    "dev:all": "concurrently \"npm run backend:dev\" \"npm run dev\"",
    "db:seed": "node scripts/seed-db.js",
    "db:reset": "cd backend && npm run db:reset"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "@react-aria/utils": "^3.34.1",
    "@react-stately/utils": "^3.12.1",
    "@react-types/overlays": "^3.10.0",
    "@react-types/shared": "^3.35.0",
    "@tailwindcss/typography": "^0.5.20",
    "@untitledui/file-icons": "^0.0.9",
    "@untitledui/icons": "^0.0.22",
    "clsx": "^2.1.1",
    "motion": "^12.40.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-aria": "^3.49.0",
    "react-aria-components": "^1.18.0",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.1.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
