{
  "name": "kupikod-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run frontend:build",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix backend && npm run lint --prefix frontend",
    "test": "npm test --prefix backend",
    "backend:dev": "npm run dev --prefix backend",
    "backend:start": "npm run start --prefix backend",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:preview": "npm run preview --prefix frontend",
    "dev:vite": "npm run dev",
    "dev:all": "npm run dev",
    "db:seed:wipe": "npm run db:seed:wipe --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
