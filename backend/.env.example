# Порт API (читается PORT или BACKEND_PORT)
PORT=4000

# SQLite (относительно папки backend/)
DATABASE_URL="file:./prisma/dev.db"

# JWT — сгенерируйте: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d

# В продакшене поставьте true (HTTPS)
COOKIE_SECURE=false

# URL фронтенда для ссылок сброса пароля
FRONTEND_URL=http://localhost:3000

# Секрет для webhook симуляции оплаты
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret
